<Routines Use="Context">
<Routine Use="Target" Name="T0P2000R11_AutoModeSqnc" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[AFI()OTE(T0P2101_ModeSqnc.iReset);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[AOI_LadderSFC_Sequencer(T0P2101_ModeSqnc,T0P2101_ModeStepData,T0P2101_ModeSqncData,T0P2101_ModeSqncData.oCurrentStepString);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[AOI_LadderSFC_Step(T0P2101_ModeStopped,T0P2101_ModeStarting.oStepNum,0,T0P2101_ModeStepData[T0P2101_ModeSqncData.diStepNum].StepName,T0P2101_ModeStepData,T0P2101_ModeSqncData);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[AOI_LadderSFC_Step(T0P2101_ModeStarting,T0P2101_ModeRunning.oStepNum,T0P2101_ModeStopping.oStepNum,T0P2101_ModeStepData[T0P2101_ModeSqncData.diStepNum].StepName,T0P2101_ModeStepData,T0P2101_ModeSqncData);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[OTE(T0P2101_ModeStarting.iTrans.0);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[AOI_LadderSFC_StepMultiFork(T0P2101_ModeRunning,0,T0P2101_ModeStopping.oStepNum,T0P2101_ModePausing.oStepNum,T0P2101_ModeClearing.oStepNum,T0P2101_ModeStopping.oStepNum,T0P2101_ModeStepData[T0P2101_ModeSqncData.diStepNum].StepName,T0P2101_ModeStepData,T0P2101_ModeSqncData);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[OTE(T0P2101_ModeRunning.iTrans.0);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[AOI_LadderSFC_Step(T0P2101_ModeStopping,T0P2101_ModeStopped.oStepNum,0,T0P2101_ModeStepData[T0P2101_ModeSqncData.diStepNum].StepName,T0P2101_ModeStepData,T0P2101_ModeSqncData);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[OTE(T0P2101_ModeStopping.iTrans.0);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[AOI_LadderSFC_Step(T0P2101_ModePausing,T0P2101_ModePaused.oStepNum,T0P2101_ModeStopping.oStepNum,T0P2101_ModeStepData[T0P2101_ModeSqncData.diStepNum].StepName,T0P2101_ModeStepData,T0P2101_ModeSqncData);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[OTE(T0P2101_ModePausing.iTrans.0);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[AOI_LadderSFC_StepMultiFork(T0P2101_ModePaused,T0P2101_ModeUnpausing.oStepNum,0,0,0,T0P2101_ModeStopping.oStepNum,T0P2101_ModeStepData[T0P2101_ModeSqncData.diStepNum].StepName,T0P2101_ModeStepData,T0P2101_ModeSqncData);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[OTE(T0P2101_ModePaused.iTrans.0);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[AOI_LadderSFC_Step(T0P2101_ModeClearing,T0P2101_ModeStopping.oStepNum,0,T0P2101_ModeStepData[T0P2101_ModeSqncData.diStepNum].StepName,T0P2101_ModeStepData,T0P2101_ModeSqncData);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[OTE(T0P2101_ModeClearing.iTrans.0);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Text>
<![CDATA[AOI_LadderSFC_Step(T0P2101_ModeUnpausing,T0P2101_ModeRunning.oStepNum,T0P2101_ModeStopping.oStepNum,T0P2101_ModeStepData[T0P2101_ModeSqncData.diStepNum].StepName,T0P2101_ModeStepData,T0P2101_ModeSqncData);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Text>
<![CDATA[OTE(T0P2101_ModeUnpausing.iTrans.0);]]>
</Text>
</Rung>
