<Controller Use="Context" Name="I250105">
<DataTypes Use="Context">
<DataType Name="UDT_LadderSFC_Sequencer" Family="NoFamily" Class="User">
<Description>
<![CDATA[Data Handoff between Sequencer & Steps
** Used for internal communcations between Sequencer & Step AOIs **]]>
</Description>
<Members>
<Member Name="diStep" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[** CURRENT STEP **
Integer Value of Current Step]]>
</Description>
</Member>
<Member Name="Step" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[** CURRENT STEP (BOOLEAN) **
Boolean Value of Current Step (Refer to Bit Address)]]>
</Description>
</Member>
<Member Name="diStepNum" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[** INTERNAL ONLY **
Used for initializing step values of Step AOIs]]>
</Description>
</Member>
<Member Name="ZZZZZZZZZZUDT_Ladder3" DataType="SINT" Dimension="0" Radix="Decimal" Hidden="true" ExternalAccess="Read/Write"/>
