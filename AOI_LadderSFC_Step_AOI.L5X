<AddOnInstructionDefinitions Use="Context">
<AddOnInstructionDefinition Use="Target" Name="AOI_LadderSFC_Step" Class="Standard" Revision="1.2" Vendor="ITG Inc." ExecutePrescan="false" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2025-02-16T18:12:18.081Z" CreatedBy="VINCITSRV\trey.zarecor" EditedDate="2025-09-09T12:57:27.320Z"
 EditedBy="VINCITSRV\trey.zarecor" SoftwareRevision="v37.01">
<RevisionNote>
<![CDATA[Re-added oneshot and ddded logic to unlatch StepThrough if sequencer is not active on the requested steop]]>
</RevisionNote>
